#!/bin/ash /etc/rc.common

START=95
STOP=10
USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/python3 /usr/lib/wifiportal/wifiportal.py
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    nft list table inet wifiportal >/dev/null 2>&1 && nft delete table inet wifiportal || true
    tc qdisc del dev br-lan root 2>/dev/null || true
    tc qdisc del dev br-lan ingress 2>/dev/null || true
    tc qdisc del dev ifb-wifiportal root 2>/dev/null || true
    ip link set ifb-wifiportal down 2>/dev/null || true
    ip link delete ifb-wifiportal 2>/dev/null || true
}

